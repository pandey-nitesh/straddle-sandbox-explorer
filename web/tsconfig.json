{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    // Vite bundles web/ — no NodeNext .js extension discipline needed here.
    // "bundler" resolution matches Vite's actual resolver (recorded decision).
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    // Browser code must never reach into server/ (redactor invariant) —
    // there is no path mapping to it, and Node ambient types are absent.
    "useDefineForClassFields": true
  },
  "include": ["src", "vite.config.ts", "vitest.config.ts"]
}
